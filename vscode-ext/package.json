{
  "name": "calkit-vscode",
  "displayName": "Calkit Notebook Environments",
  "description": "Select Calkit environments from VS Code notebook kernel flows, including nested Slurm scenarios.",
  "version": "0.0.1",
  "publisher": "calkit",
  "license": "MIT",
  "engines": {
    "vscode": "^1.95.0"
  },
  "categories": [
    "Notebooks",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "extensionDependencies": [
    "ms-toolsai.jupyter"
  ],
  "enabledApiProposals": [
    "notebookKernelSource"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "calkit-vscode.selectCalkitEnvironment",
        "title": "Calkit: Select Notebook Environment",
        "category": "Calkit"
      },
      {
        "command": "calkit-vscode.createCalkitEnvironment",
        "title": "Calkit: Create Environment",
        "category": "Calkit"
      },
      {
        "command": "calkit-vscode.startCalkitSlurmJob",
        "title": "Calkit: Start SLURM Notebook Job",
        "category": "Calkit",
        "icon": "$(debug-start)"
      },
      {
        "command": "calkit-vscode.stopCalkitSlurmJob",
        "title": "Calkit: Stop SLURM Notebook Job",
        "category": "Calkit",
        "icon": "$(debug-stop)"
      },
      {
        "command": "calkit-vscode.restartCalkitJob",
        "title": "Calkit: Restart Notebook Server",
        "category": "Calkit",
        "icon": "$(debug-restart)"
      }
    ],
    "menus": {
      "notebook/toolbar": [
        {
          "command": "calkit-vscode.selectCalkitEnvironment",
          "when": "notebookType == 'jupyter-notebook'",
          "group": "navigation@99"
        },
        {
          "command": "calkit-vscode.startCalkitSlurmJob",
          "when": "notebookType == 'jupyter-notebook' && calkit.hasResumableSlurmSession && !calkit.hasRunningSlurmSession",
          "group": "navigation@100"
        },
        {
          "command": "calkit-vscode.stopCalkitSlurmJob",
          "when": "notebookType == 'jupyter-notebook' && calkit.hasRunningSlurmSession",
          "group": "navigation@101"
        },
        {
          "command": "calkit-vscode.restartCalkitJob",
          "when": "notebookType == 'jupyter-notebook' && (calkit.hasRunningSlurmSession || calkit.hasRunningDockerSession)",
          "group": "navigation@102"
        }
      ],
      "commandPalette": [
        {
          "command": "calkit-vscode.selectCalkitEnvironment"
        },
        {
          "command": "calkit-vscode.createCalkitEnvironment"
        },
        {
          "command": "calkit-vscode.startCalkitSlurmJob"
        },
        {
          "command": "calkit-vscode.stopCalkitSlurmJob"
        },
        {
          "command": "calkit-vscode.restartCalkitJob"
        }
      ]
    },
    "configuration": {
      "title": "Calkit Notebook Environments",
      "properties": {
        "calkit.notebook.defaultJupyterPort": {
          "type": "number",
          "default": 8888,
          "description": "Default port used when launching a Calkit-backed Jupyter server."
        }
      }
    }
  },
  "scripts": {
    "compile": "tsc -p ./",
    "test": "npm run compile && node --test out/test/**/*.test.js",
    "watch": "tsc -watch -p ./",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@types/node": "^20.14.12",
    "@types/vscode": "^1.95.0",
    "typescript": "^5.6.2"
  },
  "dependencies": {
    "yaml": "^2.5.1"
  }
}
